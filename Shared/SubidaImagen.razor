@using AMPAGestion.Services
@inject ImagenService ImagenSvc
@inject Blazored.Toast.Services.IToastService Toast

<div class="mb-3">
    @if (!string.IsNullOrEmpty(UrlActual))
    {
        <div class="mb-2 d-flex align-items-center gap-3">
            <img src="@UrlActual" style="max-width:160px;max-height:120px;object-fit:cover;border-radius:8px;border:1px solid var(--bs-border-color)" alt="Imagen" />
            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="Eliminar">
                <i class="bi bi-trash me-1"></i>Eliminar imagen
            </button>
        </div>
    }

    <InputFile OnChange="Subir" accept="image/*,application/pdf" class="form-control form-control-sm" disabled="@subiendo" />

    @if (subiendo)
    {
        <div class="d-flex align-items-center gap-2 mt-1">
            <div class="spinner-border spinner-border-sm text-primary"></div>
            <small class="text-muted">Subiendo a Cloudinary...</small>
        </div>
    }
    <div class="form-text">JPG, PNG o PDF · máximo 10 MB</div>
</div>

@code {
    [Parameter] public string? UrlActual { get; set; }
    [Parameter] public EventCallback<string?> UrlActualChanged { get; set; }
    [Parameter] public string Carpeta { get; set; } = "ampa";

    bool subiendo = false;

    async Task Subir(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        const long maxBytes = 10 * 1024 * 1024;

        if (archivo.Size > maxBytes)
        {
            Toast.ShowError("El archivo no puede superar 10 MB");
            return;
        }

        subiendo = true;
        try
        {
            using var stream = archivo.OpenReadStream(maxBytes);
            var url = await ImagenSvc.SubirImagenAsync(stream, archivo.Name, Carpeta);
            if (url != null)
            {
                await UrlActualChanged.InvokeAsync(url);
                Toast.ShowSuccess("Imagen subida correctamente");
            }
            else
            {
                Toast.ShowError("Error al subir la imagen");
            }
        }
        finally
        {
            subiendo = false;
        }
    }

    async Task Eliminar()
    {
        if (!string.IsNullOrEmpty(UrlActual))
            await ImagenSvc.EliminarImagenAsync(UrlActual);
        await UrlActualChanged.InvokeAsync(null);
        Toast.ShowInfo("Imagen eliminada");
    }
}
