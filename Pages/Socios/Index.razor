@page "/socios"
@using AMPAGestion.Services
@using AMPAGestion.Models
@inject SocioService SocioSvc
@inject ContabilidadService ContSvc
@inject NavigationManager Nav
@inject Blazored.Toast.Services.IToastService Toast

<PageTitle>Socios · AMPA Gestión</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-people me-2"></i>Socios</h4>
        <small class="text-muted">Curso <strong>@cursoSeleccionado</strong></small>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <BotonesExportar Titulo="@($"Socios {cursoSeleccionado}")"
                         Columnas="@colsSocios" Filas="@FilasSocios()" />
        <a href="/socios/nuevo" class="btn btn-primary btn-sm">
            <i class="bi bi-person-plus me-1"></i>Nuevo socio
        </a>
    </div>
</div>

<!-- Filtros -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-3">
                <select class="form-select form-select-sm" @bind="cursoSeleccionado" @bind:after="Buscar">
                    @foreach (var c in CursoHelper.GetCursosDisponibles())
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Buscar socio..."
                           value="@busqueda" @oninput="OnBusquedaInput" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select form-select-sm" @bind="filtroEstado" @bind:after="AplicarFiltros">
                    <option value="">— Todos los estados —</option>
                    <option value="Pagado">✓ Pagado</option>
                    <option value="Pendiente">⏳ Pendiente</option>
                    <option value="Exento">★ Exento</option>
                    <option value="Baja">✕ Baja</option>
                </select>
            </div>
            <div class="col-md-2 text-end">
                <small class="text-muted">@sociosFiltrados.Count resultado@(sociosFiltrados.Count != 1 ? "s" : "")</small>
            </div>
        </div>
    </div>
</div>

<!-- Tabla -->
<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Socio</th>
                    <th>Contacto</th>
                    <th class="text-center">Alumnos</th>
                    <th class="text-center">Estado @cursoSeleccionado</th>
                    <th class="d-none d-md-table-cell">Cuota</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (cargando)
                {
                    <tr><td colspan="6" class="text-center py-4">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </td></tr>
                }
                else if (!sociosFiltrados.Any())
                {
                    <tr><td colspan="6" class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay socios
                    </td></tr>
                }
                else
                {
                    @foreach (var sc in sociosFiltrados)
                    {
                        <tr class="cursor-pointer" @onclick="() => VerDetalle(sc.Id)">
                            <td>
                                <div class="fw-semibold">@sc.Apellidos</div>
                                <div class="text-muted" style="font-size:.85rem">@sc.Nombre</div>
                            </td>
                            <td>
                                <div style="font-size:.88rem">@sc.Email</div>
                                <div class="text-muted" style="font-size:.83rem">@sc.Telefono</div>
                            </td>
                            <td class="text-center">
                                @if (sc.Alumnos.Any())
                                {
                                    <span class="badge bg-secondary rounded-pill">@sc.Alumnos.Count</span>
                                    <br/>
                                    <small class="text-muted">
                                        @string.Join(", ", sc.Alumnos.Select(a => a.Nombre))
                                    </small>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-center">
                                <span class="badge @BadgeClase(sc.EstadoCurso)">
                                    @BadgeIcon(sc.EstadoCurso) @sc.EstadoCurso
                                </span>
                            </td>
                            <td class="d-none d-md-table-cell">
                                @if (sc.Cuota != null)
                                {
                                    <small class="text-money text-success">@sc.Cuota.Importe.ToString("C")</small>
                                    <br/>
                                    <small class="text-muted">@sc.Cuota.Fecha.ToString("dd/MM/yyyy")</small>
                                }
                                else
                                {
                                    <button class="btn btn-xs btn-outline-success py-0 px-1"
                                            style="font-size:.78rem"
                                            @onclick:stopPropagation="true"
                                            @onclick="() => RegistrarCuotaRapida(sc.Socio)">
                                        <i class="bi bi-plus me-1"></i>Registrar cuota
                                    </button>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                    <a href="/socios/@sc.Id/editar"
                                       class="btn btn-sm btn-outline-primary py-0">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger py-0"
                                            @onclick="() => ConfirmarEliminar(sc.Socio)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal cuota rápida -->
@if (socioParaCuota != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0">
                    <h6 class="modal-title fw-bold">
                        Registrar cuota — @socioParaCuota.NombreCompleto
                    </h6>
                    <button class="btn-close" @onclick="() => socioParaCuota = null"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Importe €</label>
                            <input type="number" class="form-control" step="0.01"
                                   @bind="cuotaImporte" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Método</label>
                            <select class="form-select" @bind="cuotaMetodo">
                                @foreach (var m in Enum.GetValues<MetodoPago>())
                                { <option value="@m">@m</option> }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Curso académico</label>
                            <input class="form-control" value="@cursoSeleccionado" disabled />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-secondary btn-sm"
                            @onclick="() => socioParaCuota = null">Cancelar</button>
                    <button class="btn btn-success btn-sm" @onclick="GuardarCuotaRapida">
                        <i class="bi bi-check me-1"></i>Registrar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal confirmación borrado -->
@if (socioAEliminar != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-body text-center p-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger fs-1 mb-3 d-block"></i>
                    <p class="fw-semibold mb-1">¿Eliminar socio?</p>
                    <p class="text-muted mb-3" style="font-size:.9rem">
                        @socioAEliminar.NombreCompleto y todos sus datos asociados
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary btn-sm"
                                @onclick="() => socioAEliminar = null">Cancelar</button>
                        <button class="btn btn-danger btn-sm" @onclick="Eliminar">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "filtro")]
    public string? FiltroQuery { get; set; }

    List<SocioConCurso> todos    = new();
    List<SocioConCurso> sociosFiltrados = new();
    bool cargando             = true;
    string busqueda           = string.Empty;
    string filtroEstado       = string.Empty;
    string cursoSeleccionado  = CursoHelper.GetCursoActual();

    Socio?  socioParaCuota   = null;
    Socio?  socioAEliminar   = null;
    decimal cuotaImporte     = 25m;
    MetodoPago cuotaMetodo   = MetodoPago.Bizum;

    protected override async Task OnInitializedAsync()
    {
        if (FiltroQuery == "pendiente")
            filtroEstado = nameof(EstadoPago.Pendiente);
        await Buscar();
    }

    async Task OnBusquedaInput(ChangeEventArgs e)
    {
        busqueda = e.Value?.ToString() ?? string.Empty;
        await AplicarFiltros();
    }

    async Task Buscar()
    {
        cargando = true;
        todos = await SocioSvc.GetTodosPorCursoAsync(cursoSeleccionado);
        await AplicarFiltros();
        cargando = false;
    }

    async Task AplicarFiltros()
    {
        var q = todos.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(busqueda))
        {
            var b = busqueda.ToLower();
            q = q.Where(sc =>
                sc.Apellidos.ToLower().Contains(b) ||
                sc.Nombre.ToLower().Contains(b) ||
                (sc.Email   != null && sc.Email.ToLower().Contains(b)) ||
                (sc.DNI     != null && sc.DNI.Contains(b)));
        }

        if (!string.IsNullOrWhiteSpace(filtroEstado) &&
            Enum.TryParse<EstadoPago>(filtroEstado, out var estado))
            q = q.Where(sc => sc.EstadoCurso == estado);

        sociosFiltrados = q.ToList();
        await Task.CompletedTask;
    }

    void VerDetalle(int id) => Nav.NavigateTo($"/socios/{id}");

    void RegistrarCuotaRapida(Socio socio)
    {
        socioParaCuota = socio;
        cuotaImporte   = 25m;
        cuotaMetodo    = MetodoPago.Bizum;
    }

    async Task GuardarCuotaRapida()
    {
        if (socioParaCuota == null) return;

        var cuota = new Cuota
        {
            SocioId        = socioParaCuota.Id,
            Fecha          = DateTime.Today,
            Concepto       = $"Cuota {cursoSeleccionado}",
            Importe        = cuotaImporte,
            Metodo         = cuotaMetodo,
            CursoAcademico = cursoSeleccionado
        };

        await ContSvc.RegistrarCuotaAsync(cuota);
        Toast.ShowSuccess($"Cuota registrada para {socioParaCuota.NombreCompleto}");
        socioParaCuota = null;
        await Buscar();
    }

    void ConfirmarEliminar(Socio s) => socioAEliminar = s;

    async Task Eliminar()
    {
        if (socioAEliminar == null) return;
        await SocioSvc.EliminarAsync(socioAEliminar.Id);
        Toast.ShowSuccess($"Socio {socioAEliminar.NombreCompleto} eliminado");
        socioAEliminar = null;
        await Buscar();
    }

    string BadgeClase(EstadoPago e) => e switch
    {
        EstadoPago.Pagado    => "badge-pagado",
        EstadoPago.Pendiente => "badge-pendiente",
        EstadoPago.Exento    => "badge-exento",
        _                    => "badge-baja"
    };

    string BadgeIcon(EstadoPago e) => e switch
    {
        EstadoPago.Pagado    => "✓",
        EstadoPago.Pendiente => "⏳",
        EstadoPago.Exento    => "★",
        _                    => "✕"
    };

    static readonly string[] colsSocios = { "Apellidos", "Nombre", "Email", "Teléfono", "Estado", "Alta" };

    object[][] FilasSocios() => sociosFiltrados.Select(sc => new object[]
    {
        sc.Apellidos, sc.Nombre, sc.Email ?? "", sc.Telefono ?? "",
        sc.EstadoCurso.ToString(), sc.FechaAlta.ToString("dd/MM/yyyy")
    }).ToArray();
}
