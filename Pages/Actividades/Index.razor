@page "/actividades"
@using AMPAGestion.Services
@using AMPAGestion.Models
@inject ActividadService ActSvc
@inject Blazored.Toast.Services.IToastService Toast

<PageTitle>Actividades · AMPA Gestión</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-calendar-event me-2"></i>Actividades</h4>
    <div class="d-flex gap-2">
        <BotonesExportar Titulo="Actividades" Columnas="@colsActs" Filas="@FilasActs()" />
        <a href="/actividades/nueva" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Nueva actividad
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Buscar actividad..."
                           value="@busqueda" @oninput="OnBusquedaInput" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select form-select-sm" @bind="filtroActivas" @bind:after="Buscar">
                    <option value="">— Todas —</option>
                    <option value="true">Activas</option>
                    <option value="false">Finalizadas</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <small class="text-muted">@actividades.Count resultado@(actividades.Count != 1 ? "s" : "")</small>
            </div>
        </div>
    </div>
</div>

@if (cargando)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (!actividades.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>No hay actividades registradas
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var a in actividades)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card shadow-sm border-0 h-100">
                    @if (!string.IsNullOrEmpty(a.FotoUrl))
                    {
                        <img src="@a.FotoUrl" class="card-img-top"
                             style="height:180px;object-fit:cover;border-radius:12px 12px 0 0" alt="@a.Nombre" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light"
                             style="height:100px;border-radius:12px 12px 0 0">
                            <i class="bi bi-image text-muted" style="font-size:2rem"></i>
                        </div>
                    }
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="fw-semibold mb-0">@a.Nombre</h6>
                            <span class="badge @(a.Activa ? "badge-pagado" : "badge-baja")">
                                @(a.Activa ? "Activa" : "Finalizada")
                            </span>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            @if (a.FechaInicio.HasValue)
                            {
                                <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>@a.FechaInicio.Value.ToString("dd/MM/yyyy")</small>
                            }
                            @if (!string.IsNullOrEmpty(a.Lugar))
                            {
                                <small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@a.Lugar</small>
                            }
                            @if (a.Precio.HasValue)
                            {
                                <span class="badge bg-light text-dark">@a.Precio.Value.ToString("C")</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(a.Descripcion))
                        {
                            <p class="text-muted mb-0" style="font-size:.85rem">
                                @(a.Descripcion.Length > 100 ? a.Descripcion[..100] + "…" : a.Descripcion)
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(a.Foto2Url))
                        {
                            <img src="@a.Foto2Url" class="mt-2 rounded w-100"
                                 style="max-height:100px;object-fit:cover" alt="Imagen 2" />
                        }
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a href="/actividades/@a.Id/editar" class="btn btn-sm btn-outline-primary flex-grow-1">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminar(a)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (actividadAEliminar != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-body text-center p-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger fs-1 mb-3 d-block"></i>
                    <p class="fw-semibold mb-1">Eliminar actividad</p>
                    <p class="text-muted mb-3" style="font-size:.9rem">@actividadAEliminar.Nombre</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary btn-sm" @onclick="() => actividadAEliminar = null">Cancelar</button>
                        <button class="btn btn-danger btn-sm" @onclick="Eliminar">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<Actividad> actividades = new();
    bool cargando = true;
    string busqueda = string.Empty;
    string filtroActivas = string.Empty;
    Actividad? actividadAEliminar;

    protected override async Task OnInitializedAsync() => await Buscar();

    async Task OnBusquedaInput(ChangeEventArgs e)
    {
        busqueda = e.Value?.ToString() ?? string.Empty;
        await Buscar();
    }

    async Task Buscar()
    {
        cargando = true;
        bool? activas = filtroActivas switch { "true" => true, "false" => false, _ => null };
        actividades = await ActSvc.GetTodasAsync(busqueda, activas);
        cargando = false;
    }

    void ConfirmarEliminar(Actividad a) => actividadAEliminar = a;

    async Task Eliminar()
    {
        if (actividadAEliminar == null) return;
        await ActSvc.EliminarAsync(actividadAEliminar.Id);
        Toast.ShowSuccess("Actividad eliminada");
        actividadAEliminar = null;
        await Buscar();
    }

    static readonly string[] colsActs = { "Nombre", "Fecha inicio", "Fecha fin", "Lugar", "Precio", "Plazas", "Estado" };

    object[][] FilasActs() => actividades.Select(a => new object[]
    {
        a.Nombre,
        a.FechaInicio.HasValue ? a.FechaInicio.Value.ToString("dd/MM/yyyy") : "",
        a.FechaFin.HasValue    ? a.FechaFin.Value.ToString("dd/MM/yyyy")    : "",
        a.Lugar ?? "",
        a.Precio.HasValue ? a.Precio.Value.ToString("C") : "",
        a.PlazasMaximas.HasValue ? a.PlazasMaximas.Value.ToString() : "",
        a.Activa ? "Activa" : "Inactiva"
    }).ToArray();
}
