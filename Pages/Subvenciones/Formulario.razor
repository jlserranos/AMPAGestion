@page "/subvenciones/nueva"
@page "/subvenciones/{Id:int}/editar"
@using AMPAGestion.Services
@using AMPAGestion.Models
@inject SubvencionService SubSvc
@inject NavigationManager Nav
@inject Blazored.Toast.Services.IToastService Toast

<PageTitle>@(Id.HasValue ? "Editar subvención" : "Nueva subvención") · AMPA Gestión</PageTitle>

<div class="d-flex align-items-center gap-2 mb-4">
    <a href="/subvenciones" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">@(Id.HasValue ? "Editar subvención" : "Nueva subvención")</h4>
</div>

@if (cargando)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <EditForm Model="sub" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <div class="row g-3">

            <!-- Columna principal -->
            <div class="col-lg-8">

                <!-- Datos principales -->
                <div class="card card-form shadow-sm mb-3">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3 text-muted text-uppercase" style="font-size:.75rem">Datos de la subvención</h6>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Concepto <span class="text-danger">*</span></label>
                                <InputText @bind-Value="sub.Concepto" class="form-control"
                                           placeholder="Ej: Subvención actividades extraescolares 2025" />
                                <ValidationMessage For="() => sub.Concepto" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Origen</label>
                                <InputSelect @bind-Value="sub.Origen" class="form-select" @bind-Value:after="StateHasChanged">
                                    @foreach (var o in Enum.GetValues<OrigenSubvencion>())
                                    {
                                        <option value="@o">@DescOrigen(o)</option>
                                    }
                                </InputSelect>
                            </div>
                            @if (sub.Origen == OrigenSubvencion.Otro)
                            {
                                <div class="col-md-6">
                                    <label class="form-label">Especificar origen</label>
                                    <InputText @bind-Value="sub.OrigenPersonalizado" class="form-control"
                                               placeholder="Ej: Fundación XYZ" />
                                </div>
                            }
                            <div class="col-md-4">
                                <label class="form-label">Importe € <span class="text-danger">*</span></label>
                                <InputNumber @bind-Value="sub.Importe" class="form-control" />
                                <ValidationMessage For="() => sub.Importe" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Fecha solicitud / concesión</label>
                                <InputDate @bind-Value="sub.Fecha" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Fecha cobro</label>
                                <InputDate @bind-Value="sub.FechaCobro" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Fecha justificación</label>
                                <InputDate @bind-Value="sub.FechaJustificacion" class="form-control" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check form-switch">
                                    <InputCheckbox @bind-Value="sub.Cobrado" class="form-check-input" id="chkCobrado" />
                                    <label class="form-check-label" for="chkCobrado">Cobrado</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Comentarios</label>
                                <InputTextArea @bind-Value="sub.Comentarios" class="form-control" rows="2"
                                               placeholder="Notas sobre la tramitación, condiciones, etc." />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Observaciones</label>
                                <InputTextArea @bind-Value="sub.Observaciones" class="form-control" rows="2" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Archivos adjuntos -->
                <div class="card card-form shadow-sm mb-3">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3 text-muted text-uppercase" style="font-size:.75rem">
                            <i class="bi bi-paperclip me-1"></i>Archivos adjuntos
                            <small class="text-muted fw-normal normal-case">(resolución, justificantes, memorias…)</small>
                        </h6>
                        <SubidaMultiple
                            Url1="@sub.Foto1Url" Url2="@sub.Foto2Url" Url3="@sub.Foto3Url"
                            Url4="@sub.Foto4Url" Url5="@sub.Foto5Url" Url6="@sub.Foto6Url"
                            Nombre1="@sub.Archivo1Nombre" Nombre2="@sub.Archivo2Nombre" Nombre3="@sub.Archivo3Nombre"
                            Nombre4="@sub.Archivo4Nombre" Nombre5="@sub.Archivo5Nombre" Nombre6="@sub.Archivo6Nombre"
                            OnArchivoChanged="OnArchivoSubvencion"
                            Carpeta="ampa/subvenciones" />
                    </div>
                </div>

                <!-- Contactos -->
                <div class="card card-form shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0 text-muted text-uppercase" style="font-size:.75rem">
                                <i class="bi bi-person-lines-fill me-1"></i>Personas de contacto
                            </h6>
                            <button type="button" class="btn btn-outline-primary btn-sm py-0"
                                    @onclick="AnadirContacto">
                                <i class="bi bi-plus me-1"></i>Añadir
                            </button>
                        </div>
                        @if (!sub.Contactos.Any())
                        {
                            <p class="text-muted text-center py-2" style="font-size:.85rem">Sin contactos añadidos</p>
                        }
                        @for (int i = 0; i < sub.Contactos.Count; i++)
                        {
                            var ci = i;
                            var contacto = sub.Contactos[ci];
                            <div class="border rounded p-3 mb-2 position-relative">
                                <button type="button" class="btn btn-sm btn-outline-danger position-absolute py-0"
                                        style="top:8px;right:8px"
                                        @onclick="() => EliminarContacto(ci)">
                                    <i class="bi bi-x"></i>
                                </button>
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <label class="form-label" style="font-size:.8rem">Nombre *</label>
                                        <InputText @bind-Value="contacto.Nombre" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label" style="font-size:.8rem">Cargo</label>
                                        <InputText @bind-Value="contacto.Cargo" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label" style="font-size:.8rem">Organismo</label>
                                        <InputText @bind-Value="contacto.Organismo" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label" style="font-size:.8rem">Teléfono</label>
                                        <InputText @bind-Value="contacto.Telefono" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label" style="font-size:.8rem">Email</label>
                                        <InputText @bind-Value="contacto.Email" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label" style="font-size:.8rem">Observaciones</label>
                                        <InputText @bind-Value="contacto.Observaciones" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Alertas de plazos -->
                <div class="card card-form shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0 text-muted text-uppercase" style="font-size:.75rem">
                                <i class="bi bi-bell me-1"></i>Alertas de plazos
                            </h6>
                            <button type="button" class="btn btn-outline-warning btn-sm py-0"
                                    @onclick="AnadirAlerta">
                                <i class="bi bi-plus me-1"></i>Añadir
                            </button>
                        </div>
                        @if (!sub.Alertas.Any())
                        {
                            <p class="text-muted text-center py-2" style="font-size:.85rem">Sin alertas configuradas</p>
                        }
                        @for (int i = 0; i < sub.Alertas.Count; i++)
                        {
                            var ai = i;
                            var alerta = sub.Alertas[ai];
                            <div class="border rounded p-3 mb-2 position-relative
                                @(alerta.EstaVencida ? "border-danger bg-danger bg-opacity-10" :
                                  alerta.EsUrgente  ? "border-warning bg-warning bg-opacity-10" : "")">
                                <button type="button" class="btn btn-sm btn-outline-danger position-absolute py-0"
                                        style="top:8px;right:8px"
                                        @onclick="() => EliminarAlerta(ai)">
                                    <i class="bi bi-x"></i>
                                </button>
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-5">
                                        <label class="form-label" style="font-size:.8rem">Concepto *</label>
                                        <InputText @bind-Value="alerta.Concepto" class="form-control form-control-sm"
                                                   placeholder="Ej: Plazo justificación" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label" style="font-size:.8rem">Fecha límite</label>
                                        <InputDate @bind-Value="alerta.FechaAlerta" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label" style="font-size:.8rem">Estado</label>
                                        <InputSelect @bind-Value="alerta.Estado" class="form-select form-select-sm">
                                            @foreach (var e in Enum.GetValues<EstadoAlerta>())
                                            {
                                                <option value="@e">@e</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-2">
                                        @if (alerta.FechaAlerta > DateTime.Today)
                                        {
                                            <small class="@(alerta.EsUrgente ? "text-warning fw-bold" : "text-muted")">
                                                @alerta.DiasRestantes días
                                            </small>
                                        }
                                        else if (alerta.EstaVencida)
                                        {
                                            <small class="text-danger fw-bold">VENCIDA</small>
                                        }
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label" style="font-size:.8rem">Descripción</label>
                                        <InputText @bind-Value="alerta.Descripcion" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Columna lateral -->
            <div class="col-lg-4">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @if (guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-floppy me-1"></i>@(Id.HasValue ? "Guardar cambios" : "Crear subvención")
                    </button>
                    <a href="/subvenciones" class="btn btn-outline-secondary">Cancelar</a>
                </div>

                @if (sub.Cobrado && sub.Importe > 0)
                {
                    <div class="card border-success shadow-sm mt-3">
                        <div class="card-body text-center">
                            <div class="text-muted mb-1" style="font-size:.82rem">Importe cobrado</div>
                            <div class="fw-bold text-success text-money" style="font-size:1.6rem">
                                @sub.Importe.ToString("C")
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int? Id { get; set; }

    Subvencion sub     = new();
    bool cargando   = true;
    bool guardando  = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existente = await SubSvc.GetByIdAsync(Id.Value);
            if (existente != null) sub = existente;
            else Nav.NavigateTo("/subvenciones");
        }
        cargando = false;
    }

    void AnadirContacto() => sub.Contactos.Add(new ContactoSubvencion());
    void EliminarContacto(int i) => sub.Contactos.RemoveAt(i);
    void AnadirAlerta()   => sub.Alertas.Add(new AlertaFecha { FechaAlerta = DateTime.Today.AddDays(30) });
    void EliminarAlerta(int i) => sub.Alertas.RemoveAt(i);

    void OnArchivoSubvencion((int idx, string? url, string? nombre) args)
    {
        switch (args.idx)
        {
            case 0: sub.Foto1Url = args.url; sub.Archivo1Nombre = args.nombre; break;
            case 1: sub.Foto2Url = args.url; sub.Archivo2Nombre = args.nombre; break;
            case 2: sub.Foto3Url = args.url; sub.Archivo3Nombre = args.nombre; break;
            case 3: sub.Foto4Url = args.url; sub.Archivo4Nombre = args.nombre; break;
            case 4: sub.Foto5Url = args.url; sub.Archivo5Nombre = args.nombre; break;
            case 5: sub.Foto6Url = args.url; sub.Archivo6Nombre = args.nombre; break;
        }
    }

    async Task Guardar()
    {
        guardando = true;
        try
        {
            foreach (var c in sub.Contactos) c.SubvencionId = sub.Id;
            foreach (var a in sub.Alertas)
            {
                a.TipoEntidad   = TipoEntidadAlerta.Subvencion;
                a.SubvencionId  = sub.Id > 0 ? sub.Id : null;
            }

            if (Id.HasValue) { await SubSvc.ActualizarAsync(sub); Toast.ShowSuccess("Subvención actualizada"); }
            else             { await SubSvc.CrearAsync(sub);      Toast.ShowSuccess("Subvención creada"); }
            Nav.NavigateTo("/subvenciones");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Error: {ex.Message}");
            guardando = false;
        }
    }

    string DescOrigen(OrigenSubvencion o) => new Subvencion { Origen = o }.OrigenDescripcion;
}
