@page "/Error"
@using Microsoft.AspNetCore.Diagnostics

<PageTitle>Error</PageTitle>

<div class="container text-center mt-5">
    <i class="bi bi-exclamation-octagon text-danger display-1"></i>
    <h2 class="mt-3">Ha ocurrido un error</h2>
    <p class="text-muted">Lo sentimos, algo ha salido mal. Por favor, inténtalo de nuevo.</p>
    <a href="/" class="btn btn-primary mt-2">Volver al inicio</a>
</div>
